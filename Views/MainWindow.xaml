<Window
    x:Class="VRN.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:VRN.ViewModels"
    Title="VRN"
    Width="1320"
    Height="820"
    MinWidth="960"
    MinHeight="640"
    AllowsTransparency="False"
    Background="{DynamicResource BgPrimaryBrush}"
    FontFamily="Segoe UI"
    Foreground="{DynamicResource TextPrimaryBrush}"
    ResizeMode="CanResizeWithGrip"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="46" />
                <RowDefinition Height="*" />
                <RowDefinition Height="26" />
            </Grid.RowDefinitions>

            <!--  ══════════════════════════════════════════ CUSTOM TITLE BAR  -->
            <Border
                Grid.Row="0"
                Background="{DynamicResource BgTertiaryBrush}"
                MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <!--  Left: logo + title  -->
                    <StackPanel
                        Grid.Column="0"
                        Margin="14,0,0,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Border
                            Width="26"
                            Height="26"
                            Margin="0,0,10,0"
                            Background="{DynamicResource AccentBrush}"
                            CornerRadius="5">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="8"
                                    Opacity="0.7"
                                    ShadowDepth="0"
                                    Color="#5D8FFC" />
                            </Border.Effect>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="14"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="∑" />
                        </Border>
                        <TextBlock
                            VerticalAlignment="Center"
                            FontSize="14"
                            FontWeight="Bold"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            Text="VRN" />

                    </StackPanel>

                    <!--  Centro: navbar  -->
                    <StackPanel
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <!--  Punto 1  -->
                        <Button
                            Margin="2,0"
                            Command="{Binding NavPoint1Command}"
                            Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Padding="14,5" CornerRadius="6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPoint1}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentGlowBrush}" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentGlowBrush}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                Margin="0,0,5,0"
                                                VerticalAlignment="Center"
                                                FontSize="10"
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource AccentBrush}"
                                                Text="P1" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Text="Reed-Solomon">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPoint1}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Border
                            Width="1"
                            Height="14"
                            Margin="4,0"
                            Background="{DynamicResource BorderBrush}" />

                        <!--  Punto 2  -->
                        <Button
                            Margin="2,0"
                            Command="{Binding NavPoint2Command}"
                            Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Padding="14,5" CornerRadius="6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPoint2}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentGlowBrush}" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentGlowBrush}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                Margin="0,0,5,0"
                                                VerticalAlignment="Center"
                                                FontSize="10"
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource AccentBrush}"
                                                Text="P2" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Text="Código Lineal">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPoint2}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Border
                            Width="1"
                            Height="14"
                            Margin="4,0"
                            Background="{DynamicResource BorderBrush}" />

                        <!--  Punto 3  -->
                        <Button
                            Margin="2,0"
                            Command="{Binding NavPoint3Command}"
                            Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Padding="14,5" CornerRadius="6">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPoint3}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentGlowBrush}" />
                                                    </DataTrigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource AccentGlowBrush}" />
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock
                                                Margin="0,0,5,0"
                                                VerticalAlignment="Center"
                                                FontSize="10"
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource AccentBrush}"
                                                Text="P3" />
                                            <TextBlock
                                                VerticalAlignment="Center"
                                                FontSize="12"
                                                Text="Código Cíclico">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPoint3}" Value="True">
                                                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                                                <Setter Property="FontWeight" Value="SemiBold" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </StackPanel>

                    <!--  Right: controls  -->
                    <StackPanel
                        Grid.Column="2"
                        Margin="0,0,14,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <Button
                            Width="34"
                            Height="34"
                            Margin="0,0,2,0"
                            Command="{Binding ToggleThemeCommand}"
                            Content="◑"
                            FontSize="14"
                            Style="{StaticResource GhostButton}"
                            ToolTip="Cambiar tema" />
                        <Button
                            Width="34"
                            Height="34"
                            Margin="0,0,2,0"
                            Click="Minimize_Click"
                            Content="—"
                            FontSize="13"
                            Style="{StaticResource GhostButton}" />
                        <Button
                            Width="34"
                            Height="34"
                            Margin="0,0,2,0"
                            Click="Maximize_Click"
                            Content="⬜"
                            FontSize="11"
                            Style="{StaticResource GhostButton}" />
                        <Button
                            Width="34"
                            Height="34"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="Close_Click"
                            Content="✕"
                            Cursor="Hand"
                            FontSize="12"
                            Foreground="{DynamicResource TextSecondaryBrush}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        x:Name="Bg"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bg" Property="Background" Value="#C0E05252" />
                                            <Setter Property="Foreground" Value="White" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!--  ══════════════════════════════════════════ MAIN CONTENT  -->
            <Grid Grid.Row="1">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPoint1}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="272" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  ──────────────────────────── LEFT PANEL  -->
                <Border
                    Grid.Column="0"
                    Background="{DynamicResource BgSecondaryBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,1,0">
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="16">

                            <!--  INPUT CARD  -->
                            <Border Margin="0,0,0,14" Style="{StaticResource Card}">
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SectionHeader}" Text="PARÁMETROS" />

                                    <TextBlock Style="{StaticResource FieldLabel}" Text="N — Longitud del código" />
                                    <TextBox
                                        Margin="0,0,0,12"
                                        Style="{StaticResource ModernTextBox}"
                                        Text="{Binding InputN, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Style="{StaticResource FieldLabel}" Text="K — Dimensión" />
                                    <TextBox
                                        Margin="0,0,0,12"
                                        Style="{StaticResource ModernTextBox}"
                                        Text="{Binding InputK, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Style="{StaticResource FieldLabel}" Text="Q — Tamaño del campo (primo)" />
                                    <TextBox
                                        Margin="0,0,0,14"
                                        Style="{StaticResource ModernTextBox}"
                                        Text="{Binding InputQ, UpdateSourceTrigger=PropertyChanged}" />

                                    <!--  Validation  -->
                                    <Border
                                        Margin="0,0,0,12"
                                        Padding="10,7"
                                        Background="#1AE5A445"
                                        CornerRadius="5"
                                        Visibility="{Binding ExceedsLimit, Converter={StaticResource BoolToVis}}">
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{DynamicResource WarningBrush}"
                                            Text="{Binding ValidationMessage}"
                                            TextWrapping="Wrap" />
                                    </Border>
                                    <Border
                                        Margin="0,0,0,12"
                                        Padding="10,7"
                                        Background="#1AE05252"
                                        CornerRadius="5"
                                        Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVis}}">
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{DynamicResource ErrorBrush}"
                                            Text="{Binding ValidationMessage}"
                                            TextWrapping="Wrap" />
                                    </Border>

                                    <!--  Calculate button  -->
                                    <Button
                                        Margin="0,0,0,8"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding CalculateCommand}"
                                        Content="▶  CALCULAR"
                                        Style="{StaticResource PrimaryButton}" />

                                    <!--  Cancel button (visible while calculating)  -->
                                    <Button
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding CancelCommand}"
                                        Content="✕  Cancelar"
                                        Style="{StaticResource SecondaryButton}"
                                        Visibility="{Binding IsCalculating, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                            </Border>

                            <!--  HISTORY CARD  -->
                            <Border Style="{StaticResource Card}">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,10">
                                        <TextBlock
                                            Margin="0"
                                            DockPanel.Dock="Left"
                                            Style="{StaticResource SectionHeader}"
                                            Text="HISTORIAL" />
                                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                            <Button
                                                Width="28"
                                                Height="28"
                                                Command="{Binding History.ExportCommand}"
                                                Content="↑"
                                                FontSize="13"
                                                Style="{StaticResource GhostButton}"
                                                ToolTip="Exportar historial" />
                                            <Button
                                                Width="28"
                                                Height="28"
                                                Command="{Binding History.ImportCommand}"
                                                Content="↓"
                                                FontSize="13"
                                                Style="{StaticResource GhostButton}"
                                                ToolTip="Importar historial" />
                                        </StackPanel>
                                    </DockPanel>

                                    <TextBlock
                                        Margin="0,0,0,6"
                                        FontSize="11"
                                        Foreground="{DynamicResource SuccessBrush}"
                                        Text="{Binding History.StatusMessage}" />

                                    <ListBox
                                        MaxHeight="260"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ItemContainerStyle="{StaticResource HistoryItem}"
                                        ItemsSource="{Binding History.Entries}"
                                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                        SelectedItem="{Binding History.Selected}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock
                                                        FontSize="11.5"
                                                        FontWeight="Medium"
                                                        Foreground="{DynamicResource TextPrimaryBrush}"
                                                        Text="{Binding DisplayLabel}"
                                                        TextWrapping="Wrap" />
                                                    <StackPanel Margin="0,2,0,0" Orientation="Horizontal">
                                                        <TextBlock
                                                            FontFamily="Cascadia Mono, Consolas"
                                                            FontSize="10.5"
                                                            Foreground="{DynamicResource TextMutedBrush}">
                                                            <Run Text="d=" />
                                                            <Run Foreground="{DynamicResource AccentBrush}" Text="{Binding Result.MinimumDistance, Mode=OneWay}" />
                                                            <Run Text="  |CW|=" />
                                                            <Run Foreground="{DynamicResource TextSecondaryBrush}" Text="{Binding Result.CodewordCount, Mode=OneWay}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <Button
                                        Margin="0,10,0,0"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding LoadFromHistoryCommand}"
                                        Content="Cargar parámetros  →"
                                        Style="{StaticResource SecondaryButton}" />
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!--  ──────────────────────────── RIGHT PANEL  -->
                <Grid Grid.Column="1">

                    <!--  ═══ PROGRESS TERMINAL ═══  -->
                    <Border
                        x:Name="TerminalPanel"
                        Background="{DynamicResource TerminalBgBrush}"
                        Visibility="{Binding ShowProgress, Converter={StaticResource BoolToVis}}">
                        <Grid Margin="32,28">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Terminal header  -->
                            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                                <TextBlock
                                    Margin="0,0,0,4"
                                    FontFamily="Cascadia Mono, Consolas"
                                    FontSize="10.5"
                                    Foreground="{DynamicResource TextMutedBrush}">
                                    <Run Text="vrn" />
                                    <Run Foreground="{DynamicResource AccentBrush}" Text="@compute" />
                                    <Run Text=" ~ " />
                                    <Run Foreground="{DynamicResource TerminalAccentBrush}" Text="{Binding ProgressLabel, Mode=OneWay}" />
                                </TextBlock>
                                <Border
                                    Height="1"
                                    Background="{DynamicResource BorderBrush}"
                                    Opacity="0.5" />
                            </StackPanel>

                            <!--  Step list  -->
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding ProgressLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:ProgressLine}">
                                        <Grid
                                            x:Name="Root"
                                            Height="38"
                                            Opacity="0"
                                            RenderTransformOrigin="0,0.5">
                                            <Grid.RenderTransform>
                                                <TranslateTransform x:Name="Slide" X="-24" />
                                            </Grid.RenderTransform>
                                            <!--  Entrance animation on load  -->
                                            <Grid.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="Root"
                                                                Storyboard.TargetProperty="Opacity"
                                                                From="0"
                                                                To="1"
                                                                Duration="0:0:0.28">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="Slide"
                                                                Storyboard.TargetProperty="X"
                                                                From="-24"
                                                                To="0"
                                                                Duration="0:0:0.28">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <CubicEase EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Grid.Triggers>

                                            <DockPanel VerticalAlignment="Center">
                                                <!--  Status icon column  -->
                                                <Grid
                                                    Width="24"
                                                    Margin="0,0,12,0"
                                                    VerticalAlignment="Center"
                                                    DockPanel.Dock="Left">

                                                    <!--  Pending dot  -->
                                                    <Ellipse
                                                        x:Name="PendingDot"
                                                        Width="6"
                                                        Height="6"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Fill="{DynamicResource TextMutedBrush}" />

                                                    <!--  Running pulse  -->
                                                    <Ellipse
                                                        x:Name="RunDot"
                                                        Width="9"
                                                        Height="9"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Fill="{DynamicResource AccentBrush}"
                                                        Visibility="Collapsed">
                                                        <Ellipse.Effect>
                                                            <DropShadowEffect
                                                                BlurRadius="6"
                                                                Opacity="0.9"
                                                                ShadowDepth="0"
                                                                Color="#5D8FFC" />
                                                        </Ellipse.Effect>
                                                    </Ellipse>

                                                    <!--  Outer pulse ring  -->
                                                    <Ellipse
                                                        x:Name="PulseRing"
                                                        Width="18"
                                                        Height="18"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        Opacity="0"
                                                        Stroke="{DynamicResource AccentBrush}"
                                                        StrokeThickness="1.5"
                                                        Visibility="Collapsed" />

                                                    <!--  Success checkmark  -->
                                                    <TextBlock
                                                        x:Name="CheckMark"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="14"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource SuccessBrush}"
                                                        RenderTransformOrigin="0.5,0.5"
                                                        Text="✓"
                                                        Visibility="Collapsed">
                                                        <TextBlock.RenderTransform>
                                                            <ScaleTransform x:Name="CheckScale" ScaleX="0" ScaleY="0" />
                                                        </TextBlock.RenderTransform>
                                                        <TextBlock.Effect>
                                                            <DropShadowEffect
                                                                BlurRadius="6"
                                                                Opacity="0.7"
                                                                ShadowDepth="0"
                                                                Color="#4EC994" />
                                                        </TextBlock.Effect>
                                                    </TextBlock>

                                                    <!--  Error X  -->
                                                    <TextBlock
                                                        x:Name="ErrorMark"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center"
                                                        FontSize="13"
                                                        FontWeight="Bold"
                                                        Foreground="{DynamicResource ErrorBrush}"
                                                        Text="✕"
                                                        Visibility="Collapsed" />
                                                </Grid>

                                                <!--  Step label  -->
                                                <TextBlock
                                                    x:Name="StepLabel"
                                                    VerticalAlignment="Center"
                                                    FontFamily="Cascadia Mono, Consolas"
                                                    FontSize="12.5"
                                                    Foreground="{DynamicResource TerminalDimBrush}"
                                                    Text="{Binding Label}" />

                                                <!--  Timing / trailing dots for running  -->
                                                <TextBlock
                                                    x:Name="TrailingDots"
                                                    Margin="4,0,0,0"
                                                    VerticalAlignment="Center"
                                                    FontFamily="Cascadia Mono, Consolas"
                                                    FontSize="12.5"
                                                    Foreground="{DynamicResource AccentBrush}"
                                                    Text="..."
                                                    Visibility="Collapsed" />
                                            </DockPanel>
                                        </Grid>

                                        <!--  DataTrigger animations (must be sibling of Grid, inside DataTemplate)  -->
                                        <DataTemplate.Triggers>

                                            <!--  RUNNING state  -->
                                            <DataTrigger Binding="{Binding IsRunning}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <!--  Pulse ring animation  -->
                                                    <BeginStoryboard x:Name="PulseSB">
                                                        <Storyboard RepeatBehavior="Forever">
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="PulseRing"
                                                                Storyboard.TargetProperty="Opacity"
                                                                From="0.8"
                                                                To="0"
                                                                Duration="0:0:0.9" />
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="PulseRing"
                                                                Storyboard.TargetProperty="Width"
                                                                From="9"
                                                                To="22"
                                                                Duration="0:0:0.9" />
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="PulseRing"
                                                                Storyboard.TargetProperty="Height"
                                                                From="9"
                                                                To="22"
                                                                Duration="0:0:0.9" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <DataTrigger.ExitActions>
                                                    <StopStoryboard BeginStoryboardName="PulseSB" />
                                                </DataTrigger.ExitActions>
                                                <!--  Setters  -->
                                                <Setter TargetName="PendingDot" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="RunDot" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="PulseRing" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="TrailingDots" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="StepLabel" Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
                                            </DataTrigger>

                                            <!--  COMPLETED state  -->
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <DataTrigger.EnterActions>
                                                    <!--  Scale pop: 0 → 1.3 → 1.0  -->
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="CheckScale"
                                                                Storyboard.TargetProperty="ScaleX"
                                                                From="0"
                                                                To="1.3"
                                                                Duration="0:0:0.14">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <BackEase Amplitude="0.3" EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation
                                                                Storyboard.TargetName="CheckScale"
                                                                Storyboard.TargetProperty="ScaleY"
                                                                From="0"
                                                                To="1.3"
                                                                Duration="0:0:0.14">
                                                                <DoubleAnimation.EasingFunction>
                                                                    <BackEase Amplitude="0.3" EasingMode="EaseOut" />
                                                                </DoubleAnimation.EasingFunction>
                                                            </DoubleAnimation>
                                                            <DoubleAnimation
                                                                BeginTime="0:0:0.14"
                                                                Storyboard.TargetName="CheckScale"
                                                                Storyboard.TargetProperty="ScaleX"
                                                                To="1.0"
                                                                Duration="0:0:0.08" />
                                                            <DoubleAnimation
                                                                BeginTime="0:0:0.14"
                                                                Storyboard.TargetName="CheckScale"
                                                                Storyboard.TargetProperty="ScaleY"
                                                                To="1.0"
                                                                Duration="0:0:0.08" />
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </DataTrigger.EnterActions>
                                                <Setter TargetName="CheckMark" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="PendingDot" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="RunDot" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="PulseRing" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="TrailingDots" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="StepLabel" Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
                                            </DataTrigger>

                                            <!--  FAILED state  -->
                                            <DataTrigger Binding="{Binding IsFailed}" Value="True">
                                                <Setter TargetName="ErrorMark" Property="Visibility" Value="Visible" />
                                                <Setter TargetName="PendingDot" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="RunDot" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="PulseRing" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="TrailingDots" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="StepLabel" Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                            </DataTrigger>

                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!--  Progress bar + percentage  -->
                            <Grid Grid.Row="3" Margin="0,20,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="6" />
                                </Grid.RowDefinitions>
                                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                                    <TextBlock
                                        DockPanel.Dock="Right"
                                        FontFamily="Cascadia Mono, Consolas"
                                        FontSize="11"
                                        Foreground="{DynamicResource AccentBrush}">
                                        <Run Text="{Binding ProgressPercent, Mode=OneWay}" />
                                        <Run Text="%" />
                                    </TextBlock>
                                    <TextBlock
                                        FontFamily="Cascadia Mono, Consolas"
                                        FontSize="11"
                                        Foreground="{DynamicResource TextMutedBrush}"
                                        Text="progreso" />
                                </DockPanel>
                                <!--  Smooth progress bar via Border width binding  -->
                                <Border
                                    Grid.Row="1"
                                    Height="4"
                                    Background="{DynamicResource BorderBrush}"
                                    CornerRadius="3">
                                    <Border.Child>
                                        <Grid>
                                            <Border
                                                x:Name="ProgressFill"
                                                Height="4"
                                                HorizontalAlignment="Left"
                                                Background="{DynamicResource AccentBrush}"
                                                CornerRadius="3">
                                                <Border.Effect>
                                                    <DropShadowEffect
                                                        BlurRadius="6"
                                                        Opacity="0.8"
                                                        ShadowDepth="0"
                                                        Color="#5D8FFC" />
                                                </Border.Effect>
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Width" Value="0" />
                                                    </Style>
                                                </Border.Style>
                                            </Border>
                                        </Grid>
                                    </Border.Child>
                                </Border>
                            </Grid>

                        </Grid>
                    </Border>

                    <!--  ═══ RESULTS ═══  -->
                    <ScrollViewer
                        Padding="24,20"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto"
                        Visibility="{Binding ShowResults, Converter={StaticResource BoolToVis}}">

                        <StackPanel x:Name="ResultsPanel">
                            <StackPanel.Triggers>
                                <EventTrigger RoutedEvent="Loaded">
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation
                                                Storyboard.TargetName="ResultsPanel"
                                                Storyboard.TargetProperty="Opacity"
                                                From="0"
                                                To="1"
                                                Duration="0:0:0.4" />
                                        </Storyboard>
                                    </BeginStoryboard>
                                </EventTrigger>
                            </StackPanel.Triggers>

                            <!--  ── METRIC SUMMARY STRIP ──  -->
                            <Border
                                Margin="0,0,0,16"
                                Padding="20,16"
                                Background="{DynamicResource CardBgBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="10">
                                <Border.Effect>
                                    <DropShadowEffect
                                        BlurRadius="14"
                                        Opacity="0.18"
                                        ShadowDepth="2"
                                        Color="#000" />
                                </Border.Effect>
                                <DockPanel>
                                    <TextBlock
                                        VerticalAlignment="Bottom"
                                        DockPanel.Dock="Right"
                                        FontFamily="Cascadia Mono, Consolas"
                                        FontSize="11"
                                        Foreground="{DynamicResource TextMutedBrush}"
                                        Text="{Binding ComputeTimeText}" />
                                    <UniformGrid Columns="4" Rows="1">
                                        <!--  Metric: d min  -->
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Style="{StaticResource FieldLabel}" Text="DISTANCIA MÍN." />
                                            <TextBlock
                                                Foreground="{DynamicResource AccentBrush}"
                                                Style="{StaticResource MetricValue}"
                                                Text="{Binding AnimMinDistance}">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect
                                                        BlurRadius="8"
                                                        Opacity="0.5"
                                                        ShadowDepth="0"
                                                        Color="#5D8FFC" />
                                                </TextBlock.Effect>
                                            </TextBlock>
                                        </StackPanel>
                                        <!--  Metric: Singleton  -->
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Style="{StaticResource FieldLabel}" Text="COTA SINGLETON" />
                                            <TextBlock Style="{StaticResource MetricValue}" Text="{Binding AnimSingleton}" />
                                        </StackPanel>
                                        <!--  Metric: Codewords  -->
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Style="{StaticResource FieldLabel}" Text="PALABRAS CÓDIGO" />
                                            <TextBlock Style="{StaticResource MetricValue}" Text="{Binding AnimCodewordCount}" />
                                        </StackPanel>
                                        <!--  Metric: RS  -->
                                        <StackPanel>
                                            <TextBlock Style="{StaticResource FieldLabel}" Text="CÓDIGO RS" />
                                            <TextBlock
                                                Foreground="{DynamicResource SuccessBrush}"
                                                Style="{StaticResource MetricValue}"
                                                Text="{Binding IsRsText}">
                                                <TextBlock.Effect>
                                                    <DropShadowEffect
                                                        BlurRadius="8"
                                                        Opacity="0.4"
                                                        ShadowDepth="0"
                                                        Color="#4EC994" />
                                                </TextBlock.Effect>
                                            </TextBlock>
                                        </StackPanel>
                                    </UniformGrid>
                                </DockPanel>
                            </Border>

                            <!--  ── CODEWORDS ──  -->
                            <Expander Header="Palabras Código" Style="{StaticResource ResultExpander}">
                                <Border Padding="0,0,0,4">
                                    <DataGrid
                                        MaxHeight="280"
                                        AutoGenerateColumns="False"
                                        ItemsSource="{Binding CodewordRows}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn
                                                Width="60"
                                                Binding="{Binding Index}"
                                                Header="#" />
                                            <DataGridTextColumn
                                                Width="*"
                                                Binding="{Binding Codeword}"
                                                Header="Palabra código" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </Expander>

                            <!--  ── POLYNOMIALS ──  -->
                            <Expander Header="Polinomios p(x)" Style="{StaticResource ResultExpander}">
                                <Border Padding="0,0,0,4">
                                    <DataGrid
                                        MaxHeight="280"
                                        AutoGenerateColumns="False"
                                        ItemsSource="{Binding PolynomialRows}">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn
                                                Width="60"
                                                Binding="{Binding Index}"
                                                Header="#" />
                                            <DataGridTextColumn
                                                Width="*"
                                                Binding="{Binding Polynomial}"
                                                Header="Polinomio" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </Expander>

                            <!--  ── MATRIX G ──  -->
                            <Expander Header="Matriz Generadora G" Style="{StaticResource ResultExpander}">
                                <ScrollViewer Padding="18,8,18,14" HorizontalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding GeneratorMatrixRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ItemsControl Margin="0,1" ItemsSource="{Binding Cells}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border
                                                                Margin="2,1"
                                                                Background="{DynamicResource InputBgBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="3">
                                                                <TextBlock
                                                                    MinWidth="38"
                                                                    Padding="10,5"
                                                                    FontFamily="Cascadia Mono, Consolas"
                                                                    FontSize="12"
                                                                    Foreground="{DynamicResource AccentBrush}"
                                                                    Text="{Binding}"
                                                                    TextAlignment="Center" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Expander>

                            <!--  ── MATRIX H ──  -->
                            <Expander Header="Matriz de Paridad H" Style="{StaticResource ResultExpander}">
                                <ScrollViewer Padding="18,8,18,14" HorizontalScrollBarVisibility="Auto">
                                    <ItemsControl ItemsSource="{Binding ParityMatrixRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <ItemsControl Margin="0,1" ItemsSource="{Binding Cells}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <StackPanel Orientation="Horizontal" />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border
                                                                Margin="2,1"
                                                                Background="{DynamicResource InputBgBrush}"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="3">
                                                                <TextBlock
                                                                    MinWidth="38"
                                                                    Padding="10,5"
                                                                    FontFamily="Cascadia Mono, Consolas"
                                                                    FontSize="12"
                                                                    Foreground="{DynamicResource TerminalAccentBrush}"
                                                                    Text="{Binding}"
                                                                    TextAlignment="Center" />
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Expander>

                            <!--  ── FIELD TABLES ──  -->
                            <Expander Header="Tablas del Campo GF(q)" Style="{StaticResource ResultExpander}">
                                <Grid Margin="18,8,18,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="16" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="ADICIÓN" />
                                        <ScrollViewer MaxHeight="200" HorizontalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding AdditionTableRows}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <ItemsControl Margin="0,1" ItemsSource="{Binding Cells}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border
                                                                        Margin="1"
                                                                        Background="{DynamicResource InputBgBrush}"
                                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="2">
                                                                        <TextBlock
                                                                            MinWidth="28"
                                                                            Padding="7,4"
                                                                            FontFamily="Cascadia Mono, Consolas"
                                                                            FontSize="11"
                                                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                                                            Text="{Binding}"
                                                                            TextAlignment="Center" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource FieldLabel}" Text="MULTIPLICACIÓN" />
                                        <ScrollViewer MaxHeight="200" HorizontalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding MultiplicationTableRows}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <ItemsControl Margin="0,1" ItemsSource="{Binding Cells}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <StackPanel Orientation="Horizontal" />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Border
                                                                        Margin="1"
                                                                        Background="{DynamicResource InputBgBrush}"
                                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="2">
                                                                        <TextBlock
                                                                            MinWidth="28"
                                                                            Padding="7,4"
                                                                            FontFamily="Cascadia Mono, Consolas"
                                                                            FontSize="11"
                                                                            Foreground="{DynamicResource TextSecondaryBrush}"
                                                                            Text="{Binding}"
                                                                            TextAlignment="Center" />
                                                                    </Border>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </StackPanel>
                                </Grid>
                            </Expander>

                            <!--  ── VALIDATION MESSAGES ──  -->
                            <Expander Header="Mensajes de validación" Style="{StaticResource ResultExpander}">
                                <ItemsControl Margin="18,8,18,14" ItemsSource="{Binding Result.ValidationMessages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border
                                                Margin="0,2"
                                                Padding="10,6"
                                                CornerRadius="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{DynamicResource AccentGlowBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                <Setter Property="Background" Value="#1AE05252" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                <Setter Property="Background" Value="#1AE5A445" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock
                                                    FontSize="12"
                                                    Text="{Binding Message}"
                                                    TextWrapping="Wrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                    <Setter Property="Foreground" Value="{DynamicResource WarningBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>

                            <TextBlock Height="24" />
                        </StackPanel>
                    </ScrollViewer>

                    <!--  ═══ WELCOME / IDLE STATE ═══  -->
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding ShowResults}" Value="False" />
                                            <Condition Binding="{Binding ShowProgress}" Value="False" />
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible" />
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontFamily="Segoe UI Symbol"
                                FontSize="64"
                                FontWeight="Bold"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="∑">
                                <TextBlock.Effect>
                                    <DropShadowEffect
                                        BlurRadius="0"
                                        Opacity="0"
                                        ShadowDepth="0"
                                        Color="#5D8FFC" />
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock
                                Margin="0,8,0,4"
                                HorizontalAlignment="Center"
                                FontSize="15"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="Códigos Reed-Solomon" />
                            <TextBlock
                                HorizontalAlignment="Center"
                                FontSize="12"
                                Foreground="{DynamicResource TextMutedBrush}"
                                Text="Introduce los parámetros y pulsa Calcular" />
                        </StackPanel>
                    </Grid>

                </Grid>
            </Grid>
            <!--  Punto 2: Código Lineal Binario  -->
            <Grid Grid.Row="1">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPoint2}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="64"
                        Foreground="{DynamicResource TextMutedBrush}"
                        Text="⊞" />
                    <TextBlock
                        Margin="0,8,0,4"
                        HorizontalAlignment="Center"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextMutedBrush}"
                        Text="Código Lineal Binario" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource TextMutedBrush}"
                        Text="En construcción" />
                </StackPanel>
            </Grid>

            <!--  Punto 3: Código Cíclico  -->
            <Grid Grid.Row="1">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed" />
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsPoint3}" Value="True">
                                <Setter Property="Visibility" Value="Visible" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="64"
                        Foreground="{DynamicResource TextMutedBrush}"
                        Text="↻" />
                    <TextBlock
                        Margin="0,8,0,4"
                        HorizontalAlignment="Center"
                        FontSize="15"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource TextMutedBrush}"
                        Text="Código Cíclico" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource TextMutedBrush}"
                        Text="En construcción" />
                </StackPanel>
            </Grid>

            <!--  ══════════════════════════════════════════ STATUS BAR  -->
            <Border
                Grid.Row="2"
                Background="{DynamicResource BgTertiaryBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
                <DockPanel Margin="14,0">
                    <TextBlock
                        VerticalAlignment="Center"
                        DockPanel.Dock="Right"
                        FontFamily="Cascadia Mono, Consolas"
                        FontSize="10"
                        Foreground="{DynamicResource TextMutedBrush}"
                        Text=".NET 10 · WPF · GF(q) Engine" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="Cascadia Mono, Consolas"
                        FontSize="10"
                        Foreground="{DynamicResource TextMutedBrush}"
                        Text="{Binding ComputeTimeText}" />
                </DockPanel>
            </Border>

        </Grid>
    </Border>
</Window>
