<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ── Professional Charcoal Dark Palette ── -->
    <Color x:Key="BgPrimaryColor">#FF1A1B1E</Color>
    <Color x:Key="BgSecondaryColor">#FF212327</Color>
    <Color x:Key="BgTertiaryColor">#FF16171A</Color>
    <Color x:Key="BorderColor">#FF2E3035</Color>
    <Color x:Key="BorderHoverColor">#FF404550</Color>

    <Color x:Key="AccentColor">#FF5D8FFC</Color>
    <Color x:Key="AccentHoverColor">#FF7AAAFE</Color>
    <Color x:Key="AccentPressedColor">#FF3B6FD4</Color>
    <Color x:Key="AccentGlowColor">#3A5D8FFC</Color>

    <Color x:Key="TextPrimaryColor">#FFD4D4D4</Color>
    <Color x:Key="TextSecondaryColor">#FF858585</Color>
    <Color x:Key="TextMutedColor">#FF464646</Color>

    <Color x:Key="SuccessColor">#FF4EC994</Color>
    <Color x:Key="SuccessGlowColor">#2A4EC994</Color>
    <Color x:Key="WarningColor">#FFE5A445</Color>
    <Color x:Key="ErrorColor">#FFE05252</Color>

    <Color x:Key="TerminalBgColor">#FF111214</Color>
    <Color x:Key="TerminalAccentColor">#FF4EC994</Color>
    <Color x:Key="TerminalDimColor">#FF3A3D44</Color>

    <Color x:Key="CardBgColor">#FF252529</Color>
    <Color x:Key="InputBgColor">#FF16171A</Color>
    <Color x:Key="ScrollBarColor">#FF2E3035</Color>
    <Color x:Key="SeparatorColor">#FF252529</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BgPrimaryBrush"    Color="{StaticResource BgPrimaryColor}"/>
    <SolidColorBrush x:Key="BgSecondaryBrush"  Color="{StaticResource BgSecondaryColor}"/>
    <SolidColorBrush x:Key="BgTertiaryBrush"   Color="{StaticResource BgTertiaryColor}"/>
    <SolidColorBrush x:Key="BorderBrush"        Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderHoverBrush"   Color="{StaticResource BorderHoverColor}"/>
    <SolidColorBrush x:Key="AccentBrush"        Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush"   Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}"/>
    <SolidColorBrush x:Key="AccentGlowBrush"    Color="{StaticResource AccentGlowColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush"   Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush"     Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="SuccessBrush"       Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="SuccessGlowBrush"   Color="{StaticResource SuccessGlowColor}"/>
    <SolidColorBrush x:Key="WarningBrush"       Color="{StaticResource WarningColor}"/>
    <SolidColorBrush x:Key="ErrorBrush"         Color="{StaticResource ErrorColor}"/>
    <SolidColorBrush x:Key="TerminalBgBrush"    Color="{StaticResource TerminalBgColor}"/>
    <SolidColorBrush x:Key="TerminalAccentBrush" Color="{StaticResource TerminalAccentColor}"/>
    <SolidColorBrush x:Key="TerminalDimBrush"   Color="{StaticResource TerminalDimColor}"/>
    <SolidColorBrush x:Key="CardBgBrush"        Color="{StaticResource CardBgColor}"/>
    <SolidColorBrush x:Key="InputBgBrush"       Color="{StaticResource InputBgColor}"/>
    <SolidColorBrush x:Key="ScrollBarBrush"     Color="{StaticResource ScrollBarColor}"/>
    <SolidColorBrush x:Key="SeparatorBrush"     Color="{StaticResource SeparatorColor}"/>

</ResourceDictionary>
